# Copy to `.env` and fill with your real values.
# `.env` is gitignored. Never commit. Never share. Never paste in chat.

# ─── Anthropic (LLM content generation) ───
# Without this, falls back to template-based content (still works, less polished).
ANTHROPIC_API_KEY=

# ─── X / Twitter ───
# Get from https://console.x.com/ → Keys and tokens
# All 4 needed for posting; without them, X adapter runs in dry-run mode.
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ─── Reddit ───
# Get from https://www.reddit.com/prefs/apps → "create another app" (script type)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=orallexa-marketing-agent/0.1 by alex-jb

# ─── LinkedIn ───
# LinkedIn API is heavily restricted; v0.1 uses dry-run only.
# LINKEDIN_ACCESS_TOKEN=
